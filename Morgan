-- поиск ближайшего убийцы
local function getNearestMurderer()
    local camera = workspace.CurrentCamera
    local camPos = camera.CFrame.Position
    local closest = nil
    local dist = math.huge
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and getRole(plr) == "Murderer" and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local d = (plr.Character.HumanoidRootPart.Position - camPos).Magnitude
            if d < dist then
                dist = d
                closest = plr
            end
        end
    end
    return closest
end

-- Универсальный Silent Aim (ПК + мобильные)
local isShooting = false

local function onToolActivated()
    if isShooting then return end
    isShooting = true

    local char = player.Character
    if not char then
        isShooting = false
        return
    end

    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then
        isShooting = false
        return
    end

    -- Для оружия, отличного от Gun, просто активируем стандартно
    if tool.Name ~= "Gun" then
        tool:Activate()
        isShooting = false
        return
    end

    -- Silent Aim для Gun
    if silentAimEnabled then
        local target = getNearestMurderer()
        if target then
            local part = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            if part then
                local camera = workspace.CurrentCamera
                local oldCF = camera.CFrame
                -- Мгновенное наведение на цель
                camera.CFrame = CFrame.lookAt(oldCF.Position, part.Position)
                -- Выстрел
                tool:Activate()
                -- Возврат камеры
                camera.CFrame = oldCF
                isShooting = false
                return
            end
        end
    end

    -- Обычный выстрел, если Silent Aim выключен или цель не найдена
    tool:Activate()
    isShooting = false
end

-- Подключение к текущему инструменту и отслеживание смены
local currentToolConnection = nil

local function onToolAdded(tool)
    if currentToolConnection then
        currentToolConnection:Disconnect()
        currentToolConnection = nil
    end
    if tool and tool:IsA("Tool") then
        currentToolConnection = tool.Activated:Connect(onToolActivated)
    end
end

local function onCharacterAdded(char)
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            onToolAdded(child)
        end
    end)
    -- Подключаемся к уже существующему инструменту
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            onToolAdded(tool)
            break
        end
    end
end

if player.Character then
    onCharacterAdded(player.Character)
end
player.CharacterAdded:Connect(onCharacterAdded)
